  },
  "keywords": [
    "sap",
    "sap-fiori",
    "s4hana",
    "erp-automation",
    "browser-automation",
    "puppeteer",
    "playwright",
    "anchorbrowser",
    "nodejs"
  ],
  "license": "MIT",
  "dependencies": {
    "puppeteer": "^21.0.0",
    "dotenv": "^16.0.0",
    "otpauth": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Browser-Automation-Hub/sap-fiori-browser-automation.git"
  },
