{
  "name": "sap-fiori-browser-automation",
  "version": "1.0.0",
  "description": "Browser automation for SAP Fiori — automate procurement, manage purchase orders, extract financial data, and navigate SAP S/4HANA Fiori apps without the SAP API.",
